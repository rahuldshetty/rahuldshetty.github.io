{
  "name": "rds-blog",
  "version": "1.0.0",
  "description": "This project uses [Inscribe](https://rahuldshetty.github.io/inscribe/) to generate static HTML files from markdown files.",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "cd ../inscribe/ && bun inscribe dev ../rds-blog/",
    "build": "cd ../inscribe/ && bun inscribe build ../rds-blog/ --output ../rds-blog/dist",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "gh-pages": "^6.3.0"
  }
}
