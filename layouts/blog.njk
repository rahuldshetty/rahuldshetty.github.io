{% extends "base.njk" %}

{% block title %}{{ config.title }} | {{ blog.metadata.title }}{% endblock %}

{% block content %}
<div class="min-h-screen">


    {# Article Container #}
    <main class="max-w-2xl mx-auto px-6 py-12">

        {# Article Header #}
        <header class="mb-10">
            {% if blog.metadata.draft and isDev %}
            <div class="mb-8 p-4 rounded-xl bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-100 dark:border-yellow-900/30 flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-yellow-100 dark:bg-yellow-900/40 flex items-center justify-center text-yellow-600 dark:text-yellow-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-yellow-800 dark:text-yellow-400">Draft Preview</p>
                    <p class="text-xs text-yellow-700 dark:text-yellow-500">Draft is only available for preview. It will be hidden in production builds.</p>
                </div>
            </div>
            {% endif %}

            <h1 class="font-sans text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight text-[var(--color-text)] mb-4">
                {{ blog.metadata.title }}
            </h1>

            {% if blog.metadata.description %}
            <p class="text-xl text-[var(--color-muted)] leading-relaxed mb-6 font-medium">
                {{ blog.metadata.description }}
            </p>
            {% endif %}

            {# Meta: date + read time #}
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-6 text-sm">
                <div class="flex items-center gap-2 text-[var(--color-muted)]">
                    <time datetime="{{ blog.metadata.date }}">{{ blog.metadata.date | date if blog.metadata.date else "Unknown date" }}</time>
                </div>
                
                <span class="text-[var(--color-border)] hidden sm:inline">|</span>
                
                <div class="flex items-center gap-2 text-[var(--color-muted)] font-medium italic">
                    {{ blog.markdown | readingTime }}
                </div>
            </div>

            {# Tags #}
            {% if blog.metadata.tags and blog.metadata.tags.length %}
            <div class="flex flex-wrap gap-2 mt-5">
                {% for tag in blog.metadata.tags %}
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] hover:opacity-80 transition-opacity cursor-default">
                    {{ tag }}
                </span>
                {% endfor %}
            </div>
            {% endif %}
        </header>

        {# Cover Image #}
        {% if blog.metadata.cover %}
        <figure class="mb-10 -mx-6 sm:-mx-12">
            <img
                src="{{ blog.metadata.cover | url }}"
                alt="{{ blog.metadata.cover_alt or blog.metadata.title }}"
                class="w-full object-cover rounded-none sm:rounded-xl max-h-[480px]"
            />
            {% if blog.metadata.cover_alt %}
            <figcaption class="text-center text-sm text-[var(--color-muted)] mt-3 italic px-6">
                {{ blog.metadata.cover_alt }}
            </figcaption>
            {% endif %}
        </figure>
        {% endif %}

        {# Article Body — Typography plugin styles prose content #}
        <article class="prose prose-lg max-w-none
                        prose-headings:font-sans prose-headings:font-bold prose-headings:tracking-tight
                        prose-img:rounded-xl prose-img:shadow-sm prose-img:mx-auto">
            {{ content | safe }}
        </article>

        {# Footer divider #}
        <hr class="my-12 border-[var(--color-border)]" />

        <footer class="flex items-center justify-between text-sm text-[var(--color-muted)]">
            <a href="{{ '/blogs/' | url }}"
               class="hover:text-[var(--color-text)] transition-colors flex items-center gap-1.5 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                All posts
            </a>
            <span>{{ config.title }}</span>
        </footer>
    </main>
</div>
{% endblock %}
