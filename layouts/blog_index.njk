{% extends "base.njk" %}

{% block title %}{{ config.title }} — Blog{% endblock %}

{% block content %}
<div class="min-h-screen bg-[var(--color-bg)]">


    {# Post List #}
    <main class="max-w-2xl mx-auto px-6 py-10">

        {% if blogs and blogs.length %}
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-6">
            {{ blogs.length }} post{% if blogs.length !== 1 %}s{% endif %}
        </p>

        <ul class="divide-y divide-[var(--color-border)]">
            {% for blog in blogs %}
            <li>
                <a href="{{ blog.url | url }}"
                   class="group flex items-start justify-between gap-6 py-7 hover:no-underline">

                    {# Text content #}
                    <div class="flex-1 min-w-0">
                        <h2 class="text-xl font-bold text-[var(--color-text)] leading-snug tracking-tight group-hover:text-[var(--color-accent)] transition-colors duration-150">
                            {{ blog.metadata.title }}
                        </h2>

                        {% if blog.metadata.description or blog.metadata.excerpt %}
                        <p class="mt-2 text-sm text-[var(--color-muted)] line-clamp-2 leading-relaxed">
                            {{ blog.metadata.description or blog.metadata.excerpt }}
                        </p>
                        {% endif %}

                        <div class="flex items-center gap-3 mt-4">
                            <span class="text-xs text-[var(--color-muted)]">{{ blog.metadata.date | date if blog.metadata.date else 'Undated' }}</span>
                            <span class="text-[var(--color-border)]">·</span>
                            <span class="text-xs text-[var(--color-muted)] font-medium italic">{{ blog.markdown | readingTime }}</span>

                            {% if blog.metadata.draft and isDev %}
                            <span class="text-[var(--color-border)]">·</span>
                            <span class="inline-block text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400 font-medium border border-yellow-200 dark:border-yellow-800/50">Draft</span>
                            {% endif %}

                            {# Tags — show first 2 #}
                            {% if blog.metadata.tags and blog.metadata.tags.length %}
                            <span class="hidden sm:inline text-[var(--color-border)]">·</span>
                            <div class="hidden sm:flex items-center gap-2">
                                {% for tag in blog.metadata.tags %}
                                {% if loop.index <= 2 %}
                                <span class="inline-block text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] font-semibold uppercase tracking-wider">{{ tag }}</span>
                                {% endif %}
                                {% endfor %}
                            </div>
                            {% endif %}
                        </div>
                    </div>

                    {# Cover thumbnail #}
                    {% if blog.metadata.cover %}
                    <div class="flex-shrink-0 w-24 h-16 sm:w-32 sm:h-20 rounded-lg overflow-hidden bg-[var(--color-tag-bg)]">
                        <img
                            src="{{ blog.metadata.cover | url }}"
                            alt="{{ blog.metadata.title }}"
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        />
                    </div>
                    {% endif %}
                </a>
            </li>
            {% endfor %}
        </ul>

        {% else %}
        {# Empty state #}
        <div class="text-center py-24">
            <div class="w-14 h-14 rounded-2xl bg-[var(--color-tag-bg)] flex items-center justify-center mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[var(--color-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
            </div>
            <h2 class="text-lg font-semibold text-[var(--color-text)] mb-1">No posts yet</h2>
            <p class="text-sm text-[var(--color-muted)]">Start writing your first blog post.</p>
        </div>
        {% endif %}
    </main>
</div>
{% endblock %}
